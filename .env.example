# ── LLM key pool (Cerebras priority → Groq fallback, with rotation) ──────────
CEREBRAS_API_KEY_1=
CEREBRAS_API_KEY_2=
CEREBRAS_API_KEY_3=
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# Override the default models if you need to.
# Defaults: llama-3.3-70b on Cerebras, llama-3.3-70b-versatile on Groq.
CEREBRAS_MODEL=gpt-oss-120b
GROQ_MODEL=

# ── Deepgram (STT — Nova-3, codemix Hindi/English) ───────────────────────────
DEEPGRAM_API_KEY=

# ── Sarvam (TTS — Bulbul v3, Indian accent) ──────────────────────────────────
SARVAM_API_KEY=
SARVAM_TTS_SPEAKER=simran      # warm female; also try: manisha, vidya, arya
SARVAM_TTS_MODEL=bulbul:v3      # v2 is stable; switch to bulbul:v3 if your account has access
TTS_FILLER_CACHE=0             # 1 = replay pre-rendered short fillers ("जी","अच्छा") from cache to cut latency. Validate on a live call first.

# ── Vobiz (telephony) ───────────────────────────────────────────────────────
VOBIZ_AUTH_ID=
VOBIZ_AUTH_TOKEN=
VOBIZ_PHONE_NUMBER=           # E.164 (e.g. +1415... or +91...)

# ── Server / tunnel ──────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
PUBLIC_URL=                       # ngrok HTTPS URL (no trailing slash). e.g. https://abcd-1-2-3-4.ngrok-free.app
PANEL_PORT=5173

# ── Alpha-test target (your own mobile, E.164) ───────────────────────────────
DEMO_PHONE_NUMBER=

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=./data/aria.db

# Learn from conversion failures!!!
