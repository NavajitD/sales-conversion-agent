# ── LLM key pool ─────────────────────────────────────────────────────────────
# Cerebras (first priority — fastest inference, llama-3.3-70b)
CEREBRAS_API_KEY_1=
CEREBRAS_API_KEY_2=
CEREBRAS_API_KEY_3=

# Groq (fallback — same model family, llama-3.3-70b-versatile)
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# ── Other services ────────────────────────────────────────────────────────────
SARVAM_API_KEY=
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=          # filled after npm run create-assistant
SERVER_PUBLIC_URL=           # ngrok URL pointing at localhost:3000 (no trailing slash)
SERVER_PORT=3000
PANEL_PORT=5173
DEMO_PHONE_NUMBER=           # e.g. +919876543210
