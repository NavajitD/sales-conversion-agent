rules_version = '2';

// Aria CRM Firestore rules.
//
// Web visitor demo never talks to Firestore directly — all writes go through
// the Cloud Run service which uses the project's default service-account
// credentials and bypasses these rules. Therefore client access is denied.
// If you ever expose Firestore directly to the browser (e.g. for realtime
// dashboard reads), tighten this rule and add per-collection allowances.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
